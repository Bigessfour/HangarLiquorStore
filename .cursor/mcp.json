{
  "mcpServers": {
    "vite": {
      "url": "http://localhost:5173/__mcp/sse"
    },
    "terraform": {
      "command": "C:\\Program Files\\Docker\\Docker\\resources\\bin\\docker.exe",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "TFE_ADDRESS=${env:TFE_ADDRESS}",
        "-e",
        "TFE_TOKEN=${env:TFE_TOKEN}",
        "hashicorp/terraform-mcp-server:1.0.0"
      ]
    },
    "microsoft/playwright-mcp": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--config", "playwright-mcp.config.json"],
      "env": {
        "PATH": "C:\\Program Files\\nodejs;${env:PATH}",
        "PLAYWRIGHT_BROWSERS_PATH": ".playwright-browsers"
      }
    },
    "playwright-test": {
      "command": "npx",
      "args": ["-y", "playwright", "run-test-mcp-server"],
      "env": {
        "PATH": "C:\\Program Files\\nodejs;${env:PATH}",
        "PLAYWRIGHT_BROWSERS_PATH": ".playwright-browsers"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "env": {
        "PATH": "C:\\Program Files\\nodejs;${env:PATH}"
      }
    }
  }
}