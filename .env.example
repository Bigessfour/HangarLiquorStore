VITE_API_URL=

# Cognito (for employee login - fill after terraform apply)
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# Local demo / e2e without Cognito (do not set in production builds)
# VITE_DEMO_AUTH=true
# Quick laptop demo: npm run demo  (loads .env.demo via --mode demo)
#
# Demo simulations (representation of live Square — not a real merchant link):
# VITE_DEMO_SIMULATE_SQUARE=true
# VITE_DEMO_SIMULATE_PROFIT=true
#
# Real live Square dollars still require: deployed API, SSM credentials,
# Owner OAuth Connect, then Sync (docs/square-owner-setup.md).

# PWA install (production HTTPS deploy — required for PWABuilder)
# VITE_PWA_URL=https://YOUR-CLOUDFRONT.cloudfront.net
# iPhone permanent install: npm run iphone:install  (prints QR + Safari steps)
# Optional Android sideload APK URL after: npm run package:android -- $VITE_PWA_URL
# VITE_ANDROID_APK_URL=https://YOUR-CLOUDFRONT.cloudfront.net/hanger-liquor.apk
# Native Capacitor APK (ML Kit live scan) after: npm run build:android && npm run upload:android-apk
# VITE_NATIVE_ANDROID_APK_URL=https://YOUR-CLOUDFRONT.cloudfront.net/hanger-liquor-native.apk

# Square POS (Owner OAuth) — credentials live in AWS SSM, not here.
# See docs/square-owner-setup.md

# AWS product catalog (after terraform apply + aws login):
# npm run prep:aws

# AWS Configuration (for this repo)
# Run scripts/set-aws-profile.ps1 (Windows PowerShell) to set this automatically.
AWS_PROFILE=hanger-personal

# Backend Lambda environment
SALES_HISTORY_TABLE=HangerSalesHistory
LOCAL_EVENTS_TABLE=HangerLocalEvents
INVENTORY_TABLE=HangerInventory
STORE_ID=hanger
SAGEMAKER_ENDPOINT_NAME=
