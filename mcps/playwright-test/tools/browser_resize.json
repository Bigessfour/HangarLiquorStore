{
  "name": "browser_resize",
  "description": "Resize the browser window",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "width": {
        "type": "number",
        "description": "Width of the browser window"
      },
      "height": {
        "type": "number",
        "description": "Height of the browser window"
      },
      "intent": {
        "type": "string",
        "description": "The intent of the call, for example the test step description plan idea"
      }
    },
    "required": [
      "width",
      "height",
      "intent"
    ],
    "additionalProperties": false
  }
}