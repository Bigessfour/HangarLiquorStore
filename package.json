{
  "name": "hangar-liquor-store",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "trunk check",
    "lint:fix": "trunk fmt",
    "test:e2e": "playwright test",
    "test:backend": "npm --prefix backend test",
    "test:critical": "npm run test:backend && npm run test:e2e",
    "iphone:install": "node scripts/iphone-pwa-install.mjs",
    "iphone:install:open": "node scripts/iphone-pwa-install.mjs --open",
    "build:backend": "npm --prefix backend run build:lambdas",
    "bootstrap-owner": "npm --prefix backend exec -- tsx ../scripts/bootstrap-owner.ts",
    "setup-square-ssm": "npx tsx scripts/setup-square-ssm.ts",
    "aws:profile": "node -e \"const isWin = process.platform === 'win32'; console.log(isWin ? 'Run: npm run aws:profile:win' : 'source scripts/set-aws-profile.sh')\"",
    "aws:profile:win": "powershell -ExecutionPolicy Bypass -File scripts/set-aws-profile.ps1",
    "deploy:terraform": "cd terraform && terraform init && terraform apply -var=\"store_id=hanger\"",
    "deploy:frontend": "node scripts/deploy-frontend.mjs",
    "deploy:production": "node scripts/deploy-production.mjs",
    "export-sales-for-canvas": "npx tsx scripts/export-sales-for-canvas.ts",
    "load-products": "npx tsx scripts/load-filtered-products-to-ddb.ts",
    "generate:product-images": "node scripts/generate-product-svgs.mjs",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "build:pwa": "npm run generate:pwa-icons && npm run build",
    "package:android": "node scripts/package-android-apk.mjs",
    "cap:sync": "npx cap sync android",
    "cap:open:android": "npx cap open android",
    "build:android": "node scripts/build-android-apk.mjs",
    "build:android:release": "node scripts/build-android-apk.mjs --release",
    "upload:android-apk": "node scripts/upload-android-apk.mjs",
    "prep:aws": "npm run generate:product-images && npx tsx scripts/prep-aws-demo.ts",
    "demo": "npm run generate:product-images && VITE_DEMO_AUTH=true VITE_API_URL= VITE_COGNITO_USER_POOL_ID= VITE_COGNITO_CLIENT_ID= VITE_DEMO_NETWORK_URL=$(node scripts/get-lan-url.mjs) vite --host",
    "seed-inventory": "npx tsx scripts/seed-small-town-inventory.ts",
    "dev-setup": "node -e \"require('./scripts/dev-setup.cjs')\"",
    "seed-sales": "npx tsx scripts/seed-small-sales.ts"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^7.5.0",
    "@capacitor/android": "^7.6.7",
    "@capacitor/cli": "^7.6.7",
    "@capacitor/core": "^7.6.7",
    "@capacitor/haptics": "^7.0.5",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-toast": "^1.2.18",
    "@tanstack/react-query": "^5.69.0",
    "amazon-cognito-identity-js": "^6.3.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html5-qrcode": "2.3.8",
    "idb": "^8.0.3",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.4.0",
    "recharts": "^2.15.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-mcp": "^0.3.2",
    "vite-plugin-pwa": "^1.3.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.758.0",
    "@aws-sdk/lib-dynamodb": "^3.758.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.51.1",
    "@types/node": "^26.1.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "commander": "^12.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "postcss": "^8.5.3",
    "sharp": "^0.34.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.2.3"
  }
}
